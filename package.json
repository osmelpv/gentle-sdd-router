{
  "name": "gentle-sdd-router",
  "version": "0.1.0",
  "description": "Release-ready non-executing CLI router for SDD adoption, YAML control, and OpenCode boundary reports.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "sdd",
    "router",
    "cli",
    "adoption",
    "documentation",
    "opencode",
    "release",
    "compatibility"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osmelpv/gentle-sdd-router.git"
  },
  "homepage": "https://github.com/osmelpv/gentle-sdd-router#readme",
  "bugs": {
    "url": "https://github.com/osmelpv/gentle-sdd-router/issues"
  },
  "files": [
    "README.md",
    "assets/",
    "bin/",
    "docs/architecture.md",
    "docs/getting-started.md",
    "docs/host-adoption.en.md",
    "docs/host-adoption.es.md",
    "docs/import-export.md",
    "docs/migration-guide.md",
    "docs/presets-guide.md",
    "docs/release-checklist.md",
    "src/",
    "router/",
    "tui.tsx"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "gsr": "./bin/gsr.js"
  },
  "exports": {
    ".": "./src/cli.js",
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "theme": "gentle-sdd"
      }
    }
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@inkjs/ui": "^2.0.0",
    "fullscreen-ink": "^0.1.0",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  }
}
